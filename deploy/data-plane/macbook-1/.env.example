# ===========================================================================
# MacBook 1 (data-hot) — Environment Configuration
# ===========================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# DO NOT commit .env to git.
# ===========================================================================

# PostgreSQL credentials — must match what the k3s cluster expects
# (see deploy/k8s/overlays/homelab/secrets.yaml → settla-db-credentials)
POSTGRES_USER=settla
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# TigerBeetle cluster ID (must match across all clients)
# Default 0 is fine for homelab. Change only if running multiple clusters.
TB_CLUSTER_ID=0
