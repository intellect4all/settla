# ==========================================================================
# Multi-Machine Cluster Configuration
# Copy to .env.cluster and fill in your actual IPs.
# ==========================================================================

# Machine IPs (replace with your actual LAN IPs)
DATA_HOST=192.168.1.10        # Fedora #1 (32GB SSD) — databases
COMPUTE_HOST=192.168.1.11     # Fedora #2 (32GB)     — app services
LOADGEN_HOST=192.168.1.12     # M3 Pro Mac            — load generator

# Postgres credentials (same across all DBs)
POSTGRES_USER=settla
POSTGRES_PASSWORD=settla
SETTLA_APP_DB_PASSWORD=settla_app

# Redis
REDIS_PASSWORD=settla-dev

# JWT (generate: openssl rand -hex 32)
SETTLA_JWT_SECRET=change-me-to-a-real-secret-in-production

# Grafana
GRAFANA_ADMIN_PASSWORD=settla-grafana

# Ops API key
SETTLA_OPS_API_KEY=settla-ops-secret-change-me

# Provider mode: mock (no real blockchain) for load testing
SETTLA_PROVIDER_MODE=mock

# Mock provider delay (ms) — set to 0 for max throughput testing
SETTLA_MOCK_DELAY_MS=0

# Log level: info for load tests (debug adds overhead)
SETTLA_LOG_LEVEL=info
SETTLA_ENV=loadtest

# Tuning for 580 TPS sustained / 5,000 TPS peak
SETTLA_TREASURY_FLUSH_INTERVAL_MS=100
SETTLA_LEDGER_BATCH_WINDOW_MS=10
SETTLA_LEDGER_BATCH_MAX_SIZE=500
SETTLA_RELAY_BATCH_SIZE=500
SETTLA_RELAY_POLL_INTERVAL_MS=20
SETTLA_GRPC_POOL_SIZE=50
SETTLA_TENANT_CACHE_TTL_SECONDS=30
SETTLA_RATE_LIMIT_PER_TENANT=10000
SETTLA_LOAD_SHED_MAX_CONCURRENT=10000
SETTLA_LOAD_SHED_TARGET_LATENCY_MS=1000
SETTLA_LOAD_SHED_INITIAL_LIMIT=5000

# Worker pool sizes (tuned for 5K TPS peak)
SETTLA_WORKER_POOL_TRANSFER=16
SETTLA_WORKER_POOL_PROVIDER=32
SETTLA_WORKER_POOL_BLOCKCHAIN=16
SETTLA_WORKER_POOL_LEDGER=16
SETTLA_WORKER_POOL_TREASURY=16
SETTLA_WORKER_POOL_WEBHOOK=32
SETTLA_WORKER_POOL_INBOUND_WH=8

# NATS partitions
SETTLA_NODE_PARTITIONS=8
