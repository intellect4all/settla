{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "TigerBeetle Write Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(settla_ledger_tb_writes_total[1m])",
          "legendFormat": "writes/s",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "wps" } }
    },
    {
      "title": "TigerBeetle Write Latency (p50/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(settla_ledger_tb_write_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(settla_ledger_tb_write_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "TB Batch Size Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(settla_ledger_tb_batch_size_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(settla_ledger_tb_batch_size_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Postgres Sync Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "settla_ledger_pg_sync_lag_seconds",
          "legendFormat": "sync lag",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Treasury Flush Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "settla_treasury_flush_lag_seconds",
          "legendFormat": "flush lag",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Treasury Flush Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(settla_treasury_flush_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "NATS Partition Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "settla_nats_partition_queue_depth",
          "legendFormat": "partition {{partition}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "NATS Messages/sec by Partition",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(settla_nats_messages_total[5m])) by (partition)",
          "legendFormat": "partition {{partition}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "mps" } }
    },
    {
      "title": "Treasury Reserve Latency (ns)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(settla_treasury_reserve_latency_seconds_bucket[5m])) * 1e9",
          "legendFormat": "p99 (ns)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ns" } }
    },
    {
      "title": "Ledger Postings/sec by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(settla_ledger_postings_total[5m])) by (reference_type)",
          "legendFormat": "{{reference_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["settla", "capacity"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Capacity Planning",
  "uid": "settla-capacity"
}
