{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "templating": {
    "list": [
      {
        "name": "db",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(settla_pgxpool_max_conns, db)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "PgxPool Connections",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "PgxPool Connections by DB",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        { "expr": "settla_pgxpool_max_conns{db=~\"$db\"}", "legendFormat": "{{ db }} max", "refId": "A" },
        { "expr": "settla_pgxpool_current_conns{db=~\"$db\"}", "legendFormat": "{{ db }} active", "refId": "B" },
        { "expr": "settla_pgxpool_idle_conns{db=~\"$db\"}", "legendFormat": "{{ db }} idle", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "title": "PgxPool Utilization %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "(settla_pgxpool_current_conns{db=~\"$db\"} / settla_pgxpool_max_conns{db=~\"$db\"}) * 100",
          "legendFormat": "{{ db }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },
    {
      "title": "Database Size & Growth",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        { "expr": "settla_database_size_bytes", "legendFormat": "{{ database }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" } }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Database Growth Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        { "expr": "settla_database_growth_bytes_per_hour", "legendFormat": "{{ database }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" } }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "title": "Go Runtime",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "title": "Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "title": "Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes", "legendFormat": "{{ job }} alloc", "refId": "A" },
        { "expr": "go_memstats_heap_sys_bytes", "legendFormat": "{{ job }} sys", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum[5m]) / rate(go_gc_duration_seconds_count[5m])",
          "legendFormat": "{{ job }} avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "title": "Circuit Breakers & Resilience",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "title": "Circuit Breaker States",
      "description": "0 = CLOSED (healthy), 1 = HALF-OPEN, 2 = OPEN (tripped)",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "targets": [
        { "expr": "settla_circuit_breaker_state", "legendFormat": "{{ name }}", "instant": true, "format": "table", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "HALF-OPEN", "color": "yellow" }, "2": { "text": "OPEN", "color": "red" } } }
          ],
          "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "name": "Breaker", "Value": "State" } } }
      ]
    },
    {
      "title": "CB Failures & Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "targets": [
        { "expr": "sum by (name) (rate(settla_circuit_breaker_failures_total[5m]))", "legendFormat": "{{ name }} fail/s", "refId": "A" },
        { "expr": "sum by (name) (rate(settla_circuit_breaker_rejections_total[5m]))", "legendFormat": "{{ name }} reject/s", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" } }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      }
    },
    {
      "title": "Load Shedding",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "targets": [
        { "expr": "sum(rate(settla_loadshed_rejected_total[5m]))", "legendFormat": "Rejected/s", "refId": "A" },
        { "expr": "settla_loadshed_in_flight", "legendFormat": "In-flight", "refId": "B" },
        { "expr": "settla_loadshed_limit", "legendFormat": "Limit", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "title": "Health Checks",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },
    {
      "title": "Health Check Status",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 37 },
      "targets": [
        { "expr": "settla_health_check_status", "instant": true, "format": "table", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "check": "Component", "Value": "Status" } } }
      ]
    },
    {
      "title": "Health Check Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 37 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, check) (rate(settla_health_check_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ check }} p99",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["settla", "infrastructure"],
  "time": { "from": "now-3h", "to": "now" },
  "title": "Settla Infrastructure",
  "uid": "settla-infrastructure"
}
