{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Per-Tenant Transfer Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settla_transfers_total[5m])) by (tenant) * 60",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Per-Tenant Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settla_transfers_total{status=\"completed\"}[5m])) by (tenant) / sum(rate(settla_transfers_total[5m])) by (tenant) * 100",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Per-Tenant API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(settla_gateway_requests_total[5m])) by (tenant)",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Per-Tenant Treasury Reservations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(settla_treasury_reserve_total[5m])) by (tenant)",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Per-Tenant Treasury Positions",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "settla_treasury_balance",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["settla", "tenant"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Tenant Health",
  "uid": "settla-tenant"
}
