# ===========================================================================
# MacBook 2 (data-audit) — Environment Configuration
# ===========================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# DO NOT commit .env to git.
# ===========================================================================

# PostgreSQL credentials — must match MacBook 1 and the k3s cluster
# (see deploy/k8s/overlays/homelab/secrets.yaml → settla-db-credentials)
POSTGRES_USER=settla
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
