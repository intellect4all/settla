{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [
    { "title": "Transfer Pipeline", "url": "/d/settla-transfer-pipeline", "type": "link" },
    { "title": "Infrastructure", "url": "/d/settla-infrastructure", "type": "link" },
    { "title": "Security", "url": "/d/settla-security-reliability", "type": "link" },
    { "title": "Tenant Scale", "url": "/d/settla-tenant-scale", "type": "link" }
  ],
  "panels": [
    {
      "title": "Current TPS",
      "description": "Real-time transactions per second. Targets: 580 sustained, 5,000 peak.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settla_transfers_total[1m]))",
          "legendFormat": "TPS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "max": 6000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 200 },
              { "color": "green", "value": 500 },
              { "color": "blue", "value": 3000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Success Rate (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settla_transfers_total{status=\"completed\"}[1h])) / sum(rate(settla_transfers_total[1h])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "Success Rate (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settla_transfers_total{status=\"completed\"}[24h])) / sum(rate(settla_transfers_total[24h])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "Active Tenants",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "count(count by (tenant) (rate(settla_transfers_total[1h]) > 0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "title": "Stuck Transfers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "targets": [
        {
          "expr": "sum(settla_stuck_transfers) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "System Health %",
      "description": "100% minus 5-minute failure rate. Green ≥ 99%, Yellow ≥ 95%, Red < 95%.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "clamp_max(clamp_min((1 - (sum(rate(settla_transfers_total{status=\"failed\"}[5m])) / sum(rate(settla_transfers_total[5m])))) * 100, 0), 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "title": "Errors/s (5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settla_errors_total[5m])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "Completed Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "targets": [
        {
          "expr": "sum(increase(settla_transfers_total{status=\"completed\"}[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "title": "Outbox Backlog",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "settla_outbox_unpublished_gauge or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "DLQ Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 4 },
      "targets": [
        {
          "expr": "settla_dlq_buffer_depth or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "Flush Lag",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 4 },
      "targets": [
        {
          "expr": "settla_treasury_flush_lag_seconds or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "title": "Reconciliation Discrepancies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 4 },
      "targets": [
        {
          "expr": "sum(increase(settla_reconciliation_discrepancies_total[1h])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "title": "P50 / P99 Transfer Latency (6h)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(settla_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(settla_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(settla_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Transfer State Distribution (1h)",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (status) (increase(settla_transfers_total[1h]))",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Throughput Trend (TPS)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(settla_transfers_total[5m]))",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum(rate(settla_transfers_total{status=\"completed\"}[5m]))",
          "legendFormat": "Completed",
          "refId": "B"
        },
        {
          "expr": "sum(rate(settla_transfers_total{status=\"failed\"}[5m]))",
          "legendFormat": "Failed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["settla", "executive"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Settla Executive Overview",
  "uid": "settla-executive-overview"
}
