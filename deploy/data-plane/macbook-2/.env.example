# ===========================================================================
# MacBook 2 (data-audit) — Environment Configuration
# ===========================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# DO NOT commit .env to git.
# ===========================================================================

# PostgreSQL credentials — each DB has its own password for security isolation
# (see deploy/k8s/overlays/homelab/secrets.yaml → settla-db-credentials)
POSTGRES_USER=settla
POSTGRES_LEDGER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_TREASURY_PASSWORD=CHANGE_ME_STRONG_PASSWORD
